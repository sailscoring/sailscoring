# Sail Scoring — environment variables

# App public URL — used to generate "Open in Sail Scoring" links in exported HTML
NEXT_PUBLIC_APP_URL=https://app.sailscoring.ie

# Bilge publishing service (bilge.sailscoring.ie)
NEXT_PUBLIC_BILGE_URL=https://bilge.sailscoring.ie
NEXT_PUBLIC_BILGE_API_KEY=your-api-key-here

# --- ADR-008 Phase 1: server backend (off by default) -------------------------

# Postgres connection string. Provisioned via Neon on the Vercel Marketplace;
# pulled into .env.local with `vercel env pull`.
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# Better Auth signing secret. Generate with `openssl rand -base64 32`.
BETTER_AUTH_SECRET=replace-me

# Better Auth canonical URL — used for cookies and trusted origins. Locally
# this is http://localhost:3000; in production it matches NEXT_PUBLIC_APP_URL.
BETTER_AUTH_URL=http://localhost:3000

# Resend transactional email (magic-link delivery). Optional in dev/CI: when
# unset, magic links are written to the console and to a file under tests/.
RESEND_API_KEY=
RESEND_FROM="Sail Scoring <noreply@sailscoring.ie>"

# Phase 1 feature flag. When 'true', the UI reads/writes via the server
# backend instead of IndexedDB. Server-only (do NOT prefix with NEXT_PUBLIC_).
# Off by default; UI consumers land in Phase 3.
USE_SERVER_DATA=false
