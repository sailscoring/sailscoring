{
  "name": "sailscoring",
  "version": "0.1.0",
  "private": true,
  "description": "Sail race scoring application",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "deploy": "vercel deploy",
    "deploy:prod": "vercel deploy --prod",
    "generate:fixtures": "tsx scripts/render-scoring-fixtures.ts",
    "db:generate": "tsx --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx --env-file-if-exists=.env.local scripts/db-migrate.ts",
    "db:studio": "tsx --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs studio",
    "db:auth:generate": "better-auth generate --config lib/auth.ts --output lib/db/schema/auth.ts -y"
  },
  "dependencies": {
    "@tanstack/query-sync-storage-persister": "^5.100.6",
    "@tanstack/react-query": "^5.100.6",
    "@tanstack/react-query-persist-client": "^5.100.6",
    "@types/papaparse": "^5.5.2",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.12.0",
    "next": "16.2.4",
    "papaparse": "^5.5.3",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "resend": "^6.12.2",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.0",
    "shadcn": "^4.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "yaml": "^2.8.3"
  },
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
