{
  "name": "sailscoring",
  "version": "0.1.0",
  "private": true,
  "description": "Sail race scoring application",
  "scripts": {
    "dev": "next dev",
    "dev:local": "DATABASE_URL=postgres://sailscoring:sailscoring@localhost:5432/sailscoring next dev",
    "predev:local": "./scripts/db-up.sh",
    "build": "next build",
    "vercel-build": "tsx --env-file-if-exists=.env.local scripts/db-migrate.ts && next build",
    "start": "next start",
    "start:test": "./scripts/start-test.sh",
    "lint": "eslint",
    "test:unit": "vitest run",
    "test:unit:db": "DATABASE_URL=postgres://sailscoring:sailscoring@localhost:5432/sailscoring vitest run",
    "pretest:unit:db": "./scripts/db-up.sh",
    "test:watch": "vitest",
    "test:e2e": "DATABASE_URL=postgres://sailscoring:sailscoring@localhost:5432/sailscoring playwright test",
    "pretest:e2e": "pnpm db:migrate:test",
    "db:up": "./scripts/db-up.sh",
    "db:generate": "tsx --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx --env-file-if-exists=.env.local scripts/db-migrate.ts",
    "db:migrate:test": "DATABASE_URL=postgres://sailscoring:sailscoring@localhost:5432/sailscoring tsx scripts/db-migrate.ts",
    "db:psql:test": "psql postgres://sailscoring:sailscoring@localhost:5432/sailscoring",
    "db:studio": "tsx --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs studio",
    "db:auth:generate": "better-auth generate --config lib/auth.ts --output lib/db/schema/auth.ts -y",
    "provision-org": "tsx --env-file-if-exists=.env.local scripts/provision-org.ts",
    "provision-org:test": "DATABASE_URL=postgres://sailscoring:sailscoring@localhost:5432/sailscoring tsx scripts/provision-org.ts",
    "change-email": "tsx --env-file-if-exists=.env.local scripts/change-email.ts",
    "change-email:test": "DATABASE_URL=postgres://sailscoring:sailscoring@localhost:5432/sailscoring tsx scripts/change-email.ts",
    "delete-account": "tsx --env-file-if-exists=.env.local scripts/delete-account.ts",
    "delete-account:test": "DATABASE_URL=postgres://sailscoring:sailscoring@localhost:5432/sailscoring tsx scripts/delete-account.ts",
    "user-stats": "tsx --env-file-if-exists=.env.local scripts/user-stats.ts",
    "user-stats:test": "DATABASE_URL=postgres://sailscoring:sailscoring@localhost:5432/sailscoring tsx scripts/user-stats.ts",
    "deploy": "vercel deploy",
    "deploy:prod": "vercel deploy --prod",
    "generate:fixtures": "tsx scripts/render-scoring-fixtures.ts",
    "generate:sample-series": "tsx scripts/generate-sample-series.ts",
    "generate:rya-py": "tsx scripts/generate-rya-py.ts",
    "halsail:to-sailscoring": "tsx scripts/halsail-to-sailscoring.ts",
    "nationality:sync": "tsx scripts/sync-national-letters.ts",
    "hyc-ftp-paths": "tsx --env-file-if-exists=.env.tmp scripts/hyc-ftp-paths.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/query-sync-storage-persister": "^5.101.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "@types/papaparse": "^5.5.2",
    "@vercel/blob": "^2.4.0",
    "better-auth": "^1.6.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "papaparse": "^5.5.3",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.9.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "jsdom": "^29.1.0",
    "shadcn": "^4.10.0",
    "tailwindcss": "^4",
    "tar": "^7.5.16",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
