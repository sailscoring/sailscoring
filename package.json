{
  "name": "sailscoring",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Sail race scoring application",
  "bin": {
    "sailscoring": "./cli/sailscoring.cjs"
  },
  "scripts": {
    "dev": "next dev",
    "dev:local": "DATABASE_URL=postgres://sailscoring:sailscoring@localhost:5432/sailscoring next dev",
    "predev:local": "./scripts/db-up.sh",
    "prebuild": "pnpm canonical:sync",
    "build": "next build",
    "vercel-build": "tsx --env-file-if-exists=.env.local scripts/db-migrate.ts && pnpm build",
    "start": "next start",
    "start:test": "./scripts/start-test.sh",
    "lint": "eslint",
    "test:unit": "vitest run",
    "test:unit:db": "DATABASE_URL=postgres://sailscoring:sailscoring@localhost:5432/sailscoring vitest run",
    "pretest:unit:db": "./scripts/db-up.sh",
    "test:watch": "vitest",
    "test:e2e": "DATABASE_URL=postgres://sailscoring:sailscoring@localhost:5432/sailscoring playwright test",
    "test:e2e:triage": "./scripts/e2e-with-triage.sh",
    "flake:triage": "tsx scripts/flake-triage.ts",
    "pretest:e2e": "pnpm db:migrate:test",
    "db:up": "./scripts/db-up.sh",
    "db:generate": "tsx --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx --env-file-if-exists=.env.local scripts/db-migrate.ts",
    "db:migrate:test": "DATABASE_URL=postgres://sailscoring:sailscoring@localhost:5432/sailscoring tsx scripts/db-migrate.ts",
    "db:psql:test": "psql postgres://sailscoring:sailscoring@localhost:5432/sailscoring",
    "db:studio": "tsx --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs studio",
    "db:auth:generate": "better-auth generate --config lib/auth.ts --output lib/db/schema/auth.ts -y",
    "provision-org": "tsx --env-file-if-exists=.env.local scripts/provision-org.ts",
    "provision-org:test": "DATABASE_URL=postgres://sailscoring:sailscoring@localhost:5432/sailscoring tsx scripts/provision-org.ts",
    "provision-token": "tsx --env-file-if-exists=.env.local scripts/provision-token.ts",
    "provision-token:test": "DATABASE_URL=postgres://sailscoring:sailscoring@localhost:5432/sailscoring tsx scripts/provision-token.ts",
    "clear-idempotency": "tsx --env-file-if-exists=.env.local scripts/clear-idempotency.ts",
    "clear-idempotency:test": "DATABASE_URL=postgres://sailscoring:sailscoring@localhost:5432/sailscoring tsx scripts/clear-idempotency.ts",
    "cli": "tsx cli/index.ts",
    "change-email": "tsx --env-file-if-exists=.env.local scripts/change-email.ts",
    "change-email:test": "DATABASE_URL=postgres://sailscoring:sailscoring@localhost:5432/sailscoring tsx scripts/change-email.ts",
    "delete-account": "tsx --env-file-if-exists=.env.local scripts/delete-account.ts",
    "delete-account:test": "DATABASE_URL=postgres://sailscoring:sailscoring@localhost:5432/sailscoring tsx scripts/delete-account.ts",
    "user-stats": "tsx --env-file-if-exists=.env.local scripts/user-stats.ts",
    "user-stats:test": "DATABASE_URL=postgres://sailscoring:sailscoring@localhost:5432/sailscoring tsx scripts/user-stats.ts",
    "reconcile-identities": "tsx --env-file-if-exists=.env.local scripts/reconcile-identities.ts",
    "blw-scrub": "tsx scripts/blw-scrub.ts",
    "archive-generate": "tsx scripts/archive-generate.ts",
    "reconcile-identities:test": "DATABASE_URL=postgres://sailscoring:sailscoring@localhost:5432/sailscoring tsx scripts/reconcile-identities.ts",
    "cluster-rows": "tsx scripts/cluster-rows.ts",
    "deploy": "vercel deploy",
    "deploy:prod": "vercel deploy --prod",
    "generate:fixtures": "tsx scripts/render-scoring-fixtures.ts",
    "generate:sample-series": "tsx scripts/generate-sample-series.ts",
    "generate:rya-py": "tsx scripts/generate-rya-py.ts",
    "nationality:sync": "tsx scripts/sync-national-letters.ts",
    "canonical:sync": "tsx scripts/sync-canonical-logos.ts",
    "update-ftp-paths": "tsx --env-file-if-exists=.env.tmp scripts/update-ftp-paths.ts",
    "screenshots": "tsx scripts/screenshots.ts"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.23",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/query-sync-storage-persister": "^5.101.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-persist-client": "^5.101.2",
    "@types/papaparse": "^5.5.2",
    "@vercel/blob": "^2.6.1",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.4",
    "postgres": "^3.4.9",
    "radix-ui": "^1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "^6.17.2",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.0",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4",
    "tar": "^7.5.20",
    "tsx": "^4.23.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "overrides": {
      "kysely": "^0.28.17"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
