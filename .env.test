# .env.test
#
# Committed test configuration. Loaded by:
#   - tests/setup-env.ts (vitest setup file)
#   - scripts/start-test.sh (Playwright webServer)
#
# Values here are *not* secrets — they are test fixtures. The auth
# secret only signs cookies for whatever local DB the test is hitting;
# rotating it has no effect on production. Production secrets live in
# Vercel and are completely separate.
#
# Do NOT add DATABASE_URL here. The local URL only works against a
# host running scripts/db-up.sh; CI provides its own via a service
# container. Both paths default to the canonical local URL when
# DATABASE_URL is unset (see scripts/start-test.sh and
# tests/setup-env.ts).
#
# Do NOT add USE_SERVER_DATA here. It's a per-test-mode flag and
# belongs on the `test:e2e:server` script line, otherwise default-mode
# tests would also flip into server mode.

# Better Auth's HMAC signing key. Must be ≥32 chars; value just has to
# be stable across a test run.
BETTER_AUTH_SECRET=test-secret-32-chars-long-padding-x

# Server-side base URL Better Auth uses for redirect/callback validation.
# Must match the URL the test server actually listens on.
BETTER_AUTH_URL=http://localhost:3000

# Public-facing URL baked into the browser bundle at build time. Must
# match the URL Playwright navigates to (use.baseURL in
# playwright.config.ts).
NEXT_PUBLIC_APP_URL=http://localhost:3000
